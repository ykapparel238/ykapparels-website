---
import Logo from './Logo.astro';
import { headerNav } from '../data/site';

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href.replace(/\/$/, ''));
---

<header class="sticky top-0 z-50 border-b border-line bg-bg/85 backdrop-blur-md">
  <div class="mx-auto flex h-[4.25rem] max-w-6xl items-center justify-between gap-4 px-5 sm:px-8">
    <a href="/" class="rounded-md focus:outline-2 focus:outline-accent" aria-label="YK Apparels — home">
      <Logo />
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Main">
      {
        headerNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-ink',
              isActive(item.href) ? 'text-ink' : 'text-muted',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2.5">
      <button
        id="theme-toggle"
        type="button"
        class="relative grid size-9 place-items-center rounded-full border border-line text-muted transition-colors after:absolute after:-inset-1 after:rounded-full after:content-[''] hover:text-ink"
        aria-label="Toggle dark mode"
      >
        <svg class="size-4 dark-hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5"></circle>
          <path d="M12 2.5v2.5M12 19v2.5M2.5 12H5M19 12h2.5M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8"></path>
        </svg>
        <svg class="size-4 light-hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>

      <a
        href="/contact/"
        data-track-event="inquiry_cta_click"
        data-track-location="header_desktop"
        class="hidden rounded-full bg-accent px-4.5 py-2 text-sm font-semibold text-accent-ink transition-colors hover:bg-accent-strong sm:inline-block"
      >
        Start an inquiry
      </a>

      <button
        id="menu-toggle"
        type="button"
        class="relative grid size-9 place-items-center rounded-full border border-line text-ink after:absolute after:-inset-1 after:rounded-full after:content-[''] lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="size-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] bg-bg transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none lg:hidden"
  >
    <div class="min-h-0 overflow-hidden">
      <nav class="mx-auto flex max-w-6xl flex-col border-t border-line px-5 py-3 sm:px-8" aria-label="Mobile">
      {
        headerNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'border-b border-line py-3.5 text-[15px] font-medium last:border-b-0',
              isActive(item.href) ? 'text-accent' : 'text-ink',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a href="/contact/" data-track-event="inquiry_cta_click" data-track-location="header_mobile" class="mt-3 mb-2 rounded-full bg-accent px-5 py-2.5 text-center text-sm font-semibold text-accent-ink active:scale-[0.98]">
        Start an inquiry
      </a>
      </nav>
    </div>
  </div>
</header>

<style>
  /* icon swap driven by the html[data-theme] attribute */
  :global([data-theme='dark']) .dark-hidden {
    display: none;
  }
  :global(:root:not([data-theme='dark'])) .light-hidden {
    display: none;
  }
</style>

<script>
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
    // keep mobile browser chrome in sync with the active theme
    const tc = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');
    if (tc) tc.content = next === 'dark' ? '#0a1512' : '#14563e';
  });

  const menuBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = menuBtn?.closest('header');
  let menuOpen = false;

  function setMenu(open: boolean) {
    menuOpen = open;
    // swap (never stack) the two grid-rows utilities — with both present,
    // stylesheet order would win and the menu would stay collapsed
    menu?.classList.toggle('grid-rows-[1fr]', open);
    menu?.classList.toggle('grid-rows-[0fr]', !open);
    menuBtn?.setAttribute('aria-expanded', String(open));
    menuBtn?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }

  menuBtn?.addEventListener('click', () => setMenu(!menuOpen));

  // close on tap/click outside the header
  document.addEventListener('click', (event) => {
    if (menuOpen && header && !header.contains(event.target as Node)) setMenu(false);
  });

  // close on Escape and return focus to the toggle
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && menuOpen) {
      setMenu(false);
      menuBtn?.focus();
    }
  });

  // close when a menu link is tapped (covers hash links + slow navigations)
  menu?.addEventListener('click', (event) => {
    if ((event.target as Element).closest('a')) setMenu(false);
  });
</script>
