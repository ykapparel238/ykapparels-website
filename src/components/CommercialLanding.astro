---
import Base from '../layouts/Base.astro';
import PhotoSlot from './PhotoSlot.astro';
import FAQ from './FAQ.astro';
import CTA from './CTA.astro';
import type { CommercialPage } from '../data/commercial-pages';
import { site } from '../data/site';

interface Props {
  page: CommercialPage;
}

const { page } = Astro.props;
const canonicalPath = `/${page.slug}/`;
const serviceSchema = {
  '@type': 'Service',
  '@id': `${site.url}${canonicalPath}#service`,
  name: page.h1,
  serviceType: page.serviceType,
  description: page.description,
  url: `${site.url}${canonicalPath}`,
  provider: { '@id': `${site.url}/#organization` },
  areaServed: 'Worldwide',
  audience: { '@type': 'Audience', audienceType: page.audience },
};
---

<Base
  title={page.title}
  description={page.description}
  canonicalPath={canonicalPath}
  breadcrumbs={[{ name: page.h1, href: canonicalPath }]}
  faqItems={page.faqs}
  structuredData={[serviceSchema]}
>
  <section class="border-b border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 pt-6 sm:px-8">
      <nav aria-label="Breadcrumb" class="text-xs text-muted">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="transition-colors hover:text-accent">Home</a></li>
          <li aria-hidden="true">/</li>
          <li aria-current="page" class="text-body">{page.eyebrow}</li>
        </ol>
      </nav>
    </div>
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-14 sm:px-8 lg:grid-cols-[1.08fr_0.92fr] lg:py-20">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">{page.eyebrow}</p>
        <h1 class="font-display mt-4 max-w-3xl text-4xl font-semibold leading-tight text-ink sm:text-5xl">{page.h1}</h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">{page.lead}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="rounded-full bg-accent px-7 py-3.5 text-sm font-bold text-accent-ink transition-colors hover:bg-accent-strong">Discuss your product</a>
          <a href={site.whatsappHref} rel="noopener" target="_blank" class="rounded-full border border-line bg-surface px-7 py-3.5 text-sm font-semibold text-ink transition-colors hover:border-accent-2 hover:text-accent-2">Ask on WhatsApp</a>
        </div>
      </div>
      <PhotoSlot
        src={page.image}
        variant="sweater"
        alt={page.imageAlt}
        label={page.imageLabel}
        ratio="4 / 3"
        sizes="(min-width: 1024px) 42vw, 92vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
    <div class="grid gap-4 md:grid-cols-3">
      {page.highlights.map((item) => (
        <article class="rounded-2xl border border-line bg-surface p-7">
          <h2 class="font-display text-xl font-semibold text-ink">{item.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-y border-line bg-sunken">
    <div class="mx-auto max-w-6xl space-y-6 px-5 py-16 sm:px-8">
      {page.sections.map((section, index) => (
        <article class="grid gap-7 rounded-3xl border border-line bg-surface p-7 sm:p-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-14">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-2">{String(index + 1).padStart(2, '0')}</p>
            <h2 class="font-display mt-3 text-2xl font-semibold text-ink sm:text-3xl">{section.title}</h2>
            <p class="mt-4 leading-relaxed text-muted">{section.text}</p>
          </div>
          <ul class="grid content-center gap-3 sm:grid-cols-2">
            {section.points.map((point) => (
              <li class="flex gap-3 rounded-xl border border-line bg-bg p-4 text-sm leading-relaxed text-body">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                {point}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">Buyer questions</p>
      <h2 class="font-display mt-3 text-3xl font-semibold text-ink">What brands ask before starting</h2>
      <p class="mt-4 leading-relaxed text-muted">Clear answers early make sampling and production more predictable. Ask about anything specific to your product in the inquiry.</p>
    </div>
    <FAQ items={page.faqs} />
  </section>

  <section class="border-t border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">Continue your research</p>
      <h2 class="font-display mt-3 text-3xl font-semibold text-ink">Related manufacturing information</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {page.related.map((item) => (
          <a href={item.href} class="group rounded-2xl border border-line bg-surface p-6 transition-colors hover:border-accent-2">
            <h3 class="font-display text-lg font-semibold text-ink group-hover:text-accent-2">{item.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.text}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-accent">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="pt-20">
    <CTA title="Bring us the product you want to make" text="Send the product type, reference or tech pack, quantity and target date. We’ll review feasibility before asking you to commit." />
  </div>
</Base>
