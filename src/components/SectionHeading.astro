---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, lead, align = 'left', class: className = '' } = Astro.props;
---

<div class:list={[align === 'center' && 'mx-auto text-center', 'max-w-2xl', className]}>
  {
    eyebrow && (
      <p
        class:list={[
          'mb-3 flex items-center gap-2.5 text-xs font-semibold uppercase tracking-[0.22em] text-accent-2',
          align === 'center' && 'justify-center',
        ]}
      >
        <span class="inline-block h-px w-7 bg-accent-2" aria-hidden="true"></span>{eyebrow}
      </p>
    )
  }
  <h2 class="font-display text-3xl font-semibold text-ink sm:text-4xl">{title}</h2>
  {lead && <p class="mt-4 text-base leading-relaxed text-muted sm:text-lg">{lead}</p>}
</div>
