---
/*
  Photo figure with responsive AVIF/WebP via astro:assets. Pass `src` as a key
  from src/data/images.ts. Without `src` it falls back to themed line art, so
  the layout works before photography exists.
*/
import { Picture } from 'astro:assets';
import Illustration from './Illustration.astro';
import type { IllustrationVariant } from './Illustration.astro';
import { images, type ImageKey } from '../data/images';

interface Props {
  variant?: IllustrationVariant;
  src?: ImageKey;
  alt?: string;
  label: string;
  ratio?: string; // CSS aspect-ratio value, e.g. "4 / 3"
  sizes?: string; // responsive sizes hint matched to layout
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'auto';
  class?: string;
}
const {
  variant = 'sweater',
  src,
  alt = '',
  label,
  ratio = '4 / 3',
  sizes = '(min-width: 1024px) 45vw, 92vw',
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className = '',
} = Astro.props;
---

<figure
  class:list={['relative overflow-hidden rounded-2xl border border-line bg-sunken', className]}
  style={`aspect-ratio: ${ratio};`}
>
  {
    src ? (
      <>
        <Picture
          src={images[src]}
          alt={alt}
          formats={['avif', 'webp']}
          widths={[400, 700, 1000, 1400]}
          sizes={sizes}
          loading={loading}
          fetchpriority={fetchpriority}
          class="absolute inset-0 h-full w-full object-cover"
        />
        <figcaption class="absolute bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-white/20 bg-black/45 px-3.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-white backdrop-blur-sm">
          {label}
        </figcaption>
      </>
    ) : (
      <div class="knit-texture absolute inset-0 flex flex-col p-5">
        <span class="corner-tick top-3.5 left-3.5" />
        <span class="corner-tick top-3.5 right-3.5 rotate-90" />
        <span class="corner-tick bottom-3.5 left-3.5 -rotate-90" />
        <span class="corner-tick bottom-3.5 right-3.5 rotate-180" />
        <div class="mx-auto my-auto w-full max-w-[15rem]" style="aspect-ratio: 1;">
          <Illustration variant={variant} />
        </div>
        <figcaption class="absolute bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-line bg-surface px-3.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-muted">
          {label}
        </figcaption>
      </div>
    )
  }
</figure>

<style>
  /* astro Picture renders <picture><img/></picture>; make the img fill the frame */
  figure :global(picture) {
    position: absolute;
    inset: 0;
  }
  figure :global(picture img) {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }
  .corner-tick {
    position: absolute;
    width: 14px;
    height: 14px;
    border-top: 1.5px solid var(--accent-2);
    border-left: 1.5px solid var(--accent-2);
    opacity: 0.55;
  }
</style>
