---
import Base from '../layouts/Base.astro';
import PhotoSlot from './PhotoSlot.astro';
import FAQ from './FAQ.astro';
import CTA from './CTA.astro';
import type { CommercialPage } from '../data/commercial-pages';
import { site } from '../data/site';

interface Props {
  page: CommercialPage;
}

const { page } = Astro.props;
const canonicalPath = `/${page.slug}/`;
const serviceSchema = {
  '@type': 'Service',
  '@id': `${site.url}${canonicalPath}#service`,
  name: page.h1,
  serviceType: page.serviceType,
  description: page.description,
  url: `${site.url}${canonicalPath}`,
  provider: { '@id': `${site.url}/#organization` },
  areaServed: 'Worldwide',
  audience: { '@type': 'Audience', audienceType: page.audience },
};

const productTypes = ['Sweaters', 'Cardigans', 'Knitted polos', 'Team & event knits'];
const customDetails = [
  { title: 'Yarn & colour', text: 'Composition, shade and hand-feel' },
  { title: 'Gauge & stitch', text: 'Weight, texture and structure' },
  { title: 'Shape & fit', text: 'Measurements, grading and silhouette' },
  { title: 'Garment details', text: 'Necklines, cuffs, hems and closures' },
  { title: 'Branding', text: 'Embroidery, labels and trims' },
  { title: 'Presentation', text: 'Folding, packing and carton needs' },
] as const;
const productionSteps = [
  { number: '01', title: 'Share the idea', text: 'Send a tech pack, reference garment or clear images with quantity and timing.' },
  { number: '02', title: 'Develop the sample', text: 'We align construction, yarn, fit and branded details in a physical prototype.' },
  { number: '03', title: 'Approve the spec', text: 'Your feedback is consolidated before the final production reference is locked.' },
  { number: '04', title: 'Produce & repeat', text: 'Bulk and repeat runs follow the approved measurements, materials and finish.' },
] as const;
---

<Base
  title={page.title}
  description={page.description}
  canonicalPath={canonicalPath}
  breadcrumbs={[{ name: page.h1, href: canonicalPath }]}
  faqItems={page.faqs}
  structuredData={[serviceSchema]}
>
  <section class="border-b border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 pt-6 sm:px-8">
      <nav aria-label="Breadcrumb" class="text-xs text-muted">
        <a href="/" class="transition-colors hover:text-accent">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span aria-current="page" class="text-body">Custom knitwear</span>
      </nav>
    </div>
    <div class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-12 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:py-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">For fashion brands & private labels</p>
        <h1 class="font-display mt-4 max-w-3xl text-4xl font-semibold leading-tight text-ink sm:text-5xl">Turn your knitwear design into a production-ready garment</h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-muted sm:text-lg">
          Bring a tech pack, reference garment or early concept. YK Apparels helps you develop the sample, approve the details and manufacture the finished style.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" data-track-event="contact_click" data-track-location="custom_knitwear_hero" class="rounded-full bg-accent px-7 py-3.5 text-sm font-bold text-accent-ink transition-colors hover:bg-accent-strong">Send your design</a>
          <a href={site.whatsappHref} rel="noopener" target="_blank" data-track-event="whatsapp_click" data-track-location="custom_knitwear_hero" class="rounded-full border border-line bg-surface px-7 py-3.5 text-sm font-semibold text-ink transition-colors hover:border-accent-2 hover:text-accent-2">Ask on WhatsApp</a>
        </div>
      </div>
      <PhotoSlot
        src={page.image}
        variant="sweater"
        alt={page.imageAlt}
        label="Built around your specification"
        ratio="5 / 4"
        sizes="(min-width: 1024px) 42vw, 92vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="border-b border-line bg-surface" aria-label="Custom knitwear product types">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-8 gap-y-3 px-5 py-6 sm:px-8">
      <p class="mr-auto text-xs font-semibold uppercase tracking-[0.18em] text-muted">What we make</p>
      <ul class="flex flex-wrap gap-2.5">
        {productTypes.map((product) => (
          <li class="rounded-full border border-line bg-bg px-4 py-2 text-sm font-medium text-body">{product}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.9fr_1.1fr] lg:py-20">
    <div class="grid grid-cols-[1.15fr_0.85fr] gap-4">
      <PhotoSlot
        src="knit-texture"
        variant="sweater"
        alt="Close view of knitted texture and stitch construction"
        label="Stitch & texture"
        ratio="3 / 4"
        sizes="(min-width: 1024px) 25vw, 55vw"
      />
      <PhotoSlot
        src="yarn-spools"
        variant="yarn"
        alt="Colourful yarn cones for custom knitwear development"
        label="Yarn & colour"
        ratio="3 / 4"
        sizes="(min-width: 1024px) 18vw, 35vw"
        class="mt-10"
      />
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">Your product, not a template</p>
      <h2 class="font-display mt-3 text-3xl font-semibold leading-tight text-ink sm:text-4xl">Every visible detail can belong to your brand</h2>
      <p class="mt-5 max-w-xl leading-relaxed text-muted">
        We review the decisions that shape appearance, feel, cost and repeatability before production begins.
      </p>
      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {customDetails.map((detail) => (
          <article class="rounded-xl border border-line bg-surface p-4">
            <h3 class="text-sm font-semibold text-ink">{detail.title}</h3>
            <p class="mt-1 text-xs leading-relaxed text-muted">{detail.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 lg:py-20">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">A clear production path</p>
        <h2 class="font-display mt-3 text-3xl font-semibold text-ink sm:text-4xl">From first idea to a style you can repeat</h2>
      </div>
      <ol class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {productionSteps.map((step) => (
          <li class="rounded-2xl border border-line bg-surface p-6">
            <span class="font-display text-sm font-semibold text-accent-2">{step.number}</span>
            <h3 class="font-display mt-4 text-xl font-semibold text-ink">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted">{step.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 sm:px-8 lg:grid-cols-2 lg:py-20">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">Production control</p>
      <h2 class="font-display mt-3 text-3xl font-semibold leading-tight text-ink sm:text-4xl">The approved sample stays at the centre</h2>
      <p class="mt-5 max-w-xl leading-relaxed text-muted">
        A strong prototype only matters when production follows it. The approved measurements, materials and finish become the reference for bulk and repeat orders.
      </p>
      <ul class="mt-7 space-y-3">
        {['Checks at key production handoffs', 'Measurements reviewed against the approved chart', 'Appearance and finishing reviewed before packing'].map((item) => (
          <li class="flex items-center gap-3 text-sm text-body">
            <span class="grid size-6 shrink-0 place-items-center rounded-full bg-accent-soft text-accent-2" aria-hidden="true">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
    <PhotoSlot
      src="sewing-hands"
      variant="inspect"
      alt="Hands controlling garment construction during production"
      label="Made to the approved reference"
      ratio="4 / 3"
      sizes="(min-width: 1024px) 45vw, 92vw"
    />
  </section>

  <section class="border-y border-line bg-sunken">
    <div class="mx-auto grid max-w-5xl gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[0.65fr_1.35fr]">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-2">Before you start</p>
        <h2 class="font-display mt-3 text-3xl font-semibold text-ink">Three useful answers</h2>
      </div>
      <FAQ items={page.faqs} />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="flex flex-col gap-5 border-b border-line pb-14 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted">Continue planning</p>
        <h2 class="font-display mt-2 text-2xl font-semibold text-ink">Useful next steps</h2>
      </div>
      <div class="flex flex-wrap gap-2.5">
        {page.related.map((item) => (
          <a href={item.href} class="rounded-full border border-line bg-surface px-5 py-2.5 text-sm font-semibold text-body transition-colors hover:border-accent-2 hover:text-accent-2">{item.label} →</a>
        ))}
      </div>
    </div>
  </section>

  <CTA title="Ready to develop the first sample?" text="Send the product type, reference or tech pack, quantity and target date. We’ll start with the decisions that affect feasibility." />
</Base>
