---
import { processSteps } from '../data/content';
---

<ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
  {
    processSteps.map((step, i) => (
      <li class="group relative rounded-2xl border border-line bg-surface p-6 transition-colors hover:border-accent/50">
        <span class="font-display text-4xl font-semibold text-accent/25 transition-colors group-hover:text-accent/50">
          {String(i + 1).padStart(2, '0')}
        </span>
        <h3 class="mt-3 text-[15px] font-semibold text-ink">{step.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted">{step.text}</p>
      </li>
    ))
  }
</ol>
