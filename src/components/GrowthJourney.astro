---
/*
  The partnership growth path: a stitched thread connecting milestones
  from a single piece to full production. Used on Home and Capabilities.
*/
import { smallRuns } from '../data/content';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<ol class:list={['relative', className]}>
  <!-- the thread -->
  <span
    class="pointer-events-none absolute bottom-8 left-[1.32rem] top-6 border-l-2 border-dashed border-accent-2/35"
    aria-hidden="true"></span>

  {
    smallRuns.map((run) => (
      <li class="group relative flex gap-5 pb-9">
        <span class="z-10 mt-1 grid size-11 shrink-0 place-items-center rounded-full border-2 border-accent-2/50 bg-surface transition-all duration-300 group-hover:scale-110 group-hover:border-accent-2 group-hover:bg-accent-2">
          <svg
            class="size-4 text-accent-2 transition-colors group-hover:text-white"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 8l7 7 7-7" />
          </svg>
        </span>
        <div>
          <p class="font-display text-2xl font-semibold leading-tight text-accent-2">{run.moq}</p>
          <h3 class="mt-1.5 text-[0.8rem] font-bold uppercase tracking-[0.14em] text-ink">{run.audience}</h3>
          <p class="mt-2 max-w-md text-sm leading-relaxed text-muted">{run.text}</p>
        </div>
      </li>
    ))
  }

  <!-- where the thread leads -->
  <li class="relative flex gap-5">
    <span class="z-10 mt-1 grid size-11 shrink-0 place-items-center rounded-full bg-accent-2">
      <svg
        class="size-4"
        style="color: var(--surface);"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M7 17 17 7M8 7h9v9" />
      </svg>
    </span>
    <div class="flex-1 rounded-2xl bg-accent-soft px-6 py-5">
      <p class="font-display text-2xl font-semibold leading-tight text-ink">…to your thousandth piece</p>
      <p class="mt-2 max-w-md text-sm leading-relaxed text-body">
        When volume comes, you won't need to search for a new manufacturer. The partner who made
        your first piece already runs full production lines.
      </p>
    </div>
  </li>
</ol>
