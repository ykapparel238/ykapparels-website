---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PhotoSlot from '../components/PhotoSlot.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
import { qualityPoints, keyFacts } from '../data/content';

const values = [
  {
    title: 'Honest answers first',
    text: 'If a price, timeline or construction won’t work, we say so before you commit — not after.',
  },
  {
    title: 'Discipline over promises',
    text: 'Daily output tracking by style, stage and shift keeps our commitments grounded in real numbers.',
  },
  {
    title: 'Long-term partners',
    text: 'We document approved specifications so successful products have a controlled path to repeat production.',
  },
] as const;
---

<Base
  title="About YK Apparels — Knitwear Manufacturer in Lahore"
  description="YK Apparels has manufactured knitwear and apparel in Lahore, Pakistan since 2015. See our production facility, quality process and how we work with brands."
>
  <section class="mx-auto grid max-w-6xl items-center gap-12 px-5 pt-16 pb-12 sm:px-8 lg:grid-cols-[1.1fr_1fr] lg:pt-20">
    <div>
      <SectionHeading
        as="h1"
        eyebrow="About us"
        title="A knitwear manufacturer built on repeat orders"
        lead={`YK Apparels has been manufacturing knitwear and apparel in Lahore since ${site.founded}. We grew the way good manufacturers do — one delivered order at a time, for brands that kept coming back.`}
      />
      <p class="mt-6 max-w-xl leading-relaxed text-muted">
        Today we produce for established Pakistani high-street brands and welcome inquiries from
        labels in other markets. What hasn't changed is how we operate: honest
        feasibility answers, disciplined production tracking, and quality checked at every stage —
        not just at final inspection. Explore our
        <a href="/capabilities/" class="font-semibold text-accent-2 underline underline-offset-2">knitwear manufacturing capabilities</a>
        or <a href="/contact/" class="font-semibold text-accent-2 underline underline-offset-2">start a production inquiry</a>.
      </p>
    </div>
    <PhotoSlot
      variant="machine"
      src="factory-machines"
      alt="Rows of textile machinery with yarn bobbins"
      label="Our facility"
      ratio="4 / 4.4"
    />
  </section>

  <!-- At a glance: plain facts, easy for buyers (and AI assistants) to quote -->
  <section class="mx-auto max-w-6xl px-5 pb-14 sm:px-8" aria-label="YK Apparels at a glance">
    <div class="rounded-3xl border border-line bg-surface p-7 sm:p-10">
      <SectionHeading eyebrow="At a glance" title="The facts, in one place" />
      <dl class="mt-8 grid gap-x-10 gap-y-5 sm:grid-cols-2">
        {
          keyFacts.map((fact) => (
            <div class="grid grid-cols-[9.5rem_1fr] gap-3 border-b border-line pb-4">
              <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">{fact.label}</dt>
              <dd class="text-sm leading-relaxed text-body">{fact.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Facility -->
  <section class="border-y border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
      <SectionHeading
        eyebrow="The facility"
        title="Where your garments are made"
        lead="Knitting, linking, stitching, embroidery, finishing and packing — all inside one facility on Raiwind Road, Lahore."
        align="center"
      />
      <div class="mt-11 grid gap-4 sm:grid-cols-3">
        <PhotoSlot
          variant="machine"
          src="workshop"
          alt="Production floor with rows of sewing stations"
          label="Production floor"
          ratio="4 / 3"
        />
        <PhotoSlot
          variant="embroidery"
          src="sewing-machine"
          alt="Sewing machine needle stitching fabric"
          label="Stitching & linking"
          ratio="4 / 3"
        />
        <PhotoSlot
          variant="carton"
          src="sweaters-stack"
          alt="Finished sweaters folded and stacked"
          label="Finishing & packing"
          ratio="4 / 3"
        />
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-4 sm:grid-cols-3">
        {
          [
            { value: 'Multi-line', label: 'Production setup' },
            { value: 'In-house', label: 'Embroidery & finishing' },
            { value: 'One roof', label: 'Yarn to carton' },
          ].map((item) => (
            <div class="rounded-2xl border border-line bg-surface p-6 text-center">
              <p class="font-display text-xl font-semibold text-ink">{item.value}</p>
              <p class="mt-1.5 text-xs font-medium uppercase tracking-[0.16em] text-muted">{item.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Quality -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <SectionHeading
      eyebrow="Quality"
      title="How we protect your spec"
      lead="Quality is a process property, not an inspection event. Here is what that means in practice."
    />
    <div class="mt-11 grid gap-4 sm:grid-cols-2">
      {
        qualityPoints.map((point) => (
          <div class="rounded-2xl border border-line bg-surface p-7">
            <h3 class="text-[15px] font-semibold text-ink">{point.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-muted">{point.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Process -->
  <section class="border-y border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
      <SectionHeading eyebrow="How we work" title="Our five-step process" align="center" />
      <div class="mt-11">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <SectionHeading eyebrow="What we stand for" title="Three things we won't compromise" align="center" />
    <div class="mx-auto mt-11 grid max-w-4xl gap-4 sm:grid-cols-3">
      {
        values.map((value) => (
          <div class="rounded-2xl border border-line bg-surface p-7 text-center">
            <h3 class="font-display text-lg font-semibold text-ink">{value.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-muted">{value.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CTA />
</Base>
