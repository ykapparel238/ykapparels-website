---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — YK Apparels" description="The page you were looking for doesn't exist.">
  <section class="mx-auto max-w-6xl px-5 py-28 text-center sm:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">404</p>
    <h1 class="font-display mt-4 text-4xl font-semibold text-ink">This page slipped a stitch</h1>
    <p class="mx-auto mt-4 max-w-md text-muted">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full bg-accent px-7 py-3 text-sm font-semibold text-accent-ink transition-colors hover:bg-accent-strong"
    >
      Back to home
    </a>
  </section>
</Base>
