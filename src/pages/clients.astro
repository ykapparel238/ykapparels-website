---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ClientLogos from '../components/ClientLogos.astro';
import CTA from '../components/CTA.astro';
---

<Base
  title="Clients — Brands That Manufacture With YK Apparels"
  description="YK Apparels manufactures garments for leading Pakistani brands including Breakout, Hopscotch and Fitted — and partners with international fashion labels."
>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-4 sm:px-8 lg:pt-20">
    <SectionHeading
      as="h1"
      eyebrow="Clients"
      title="Brands that produce with us"
      lead="Manufacturing is a trust business. Ours has been earned order by order with some of Pakistan's most recognised brands — the same standard we bring to international partners."
    />
  </section>

  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <ClientLogos showNotes />
    <p class="mt-6 text-sm text-muted">
      …and more. We're happy to share references relevant to your product category on request.
    </p>
  </section>

  <section class="border-y border-line bg-sunken">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
      <SectionHeading eyebrow="A dependable process" title="What a brand can evaluate before ordering" align="center" />
      <div class="mx-auto mt-11 grid max-w-5xl gap-4 sm:grid-cols-3">
        <article class="rounded-2xl border border-line bg-surface p-8">
          <h2 class="font-display text-xl font-semibold text-ink">Relevant product experience</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">Ask for examples aligned with your garment type, construction and quality level before development begins.</p>
        </article>
        <article class="rounded-2xl border border-line bg-surface p-8">
          <h2 class="font-display text-xl font-semibold text-ink">A controlled approval path</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">Use a written specification and approved physical sample to define what production must reproduce.</p>
        </article>
        <article class="rounded-2xl border border-line bg-surface p-8">
          <h2 class="font-display text-xl font-semibold text-ink">Clear production communication</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">Agree the owner, checkpoints and evidence for material, quality, packing and delivery decisions.</p>
        </article>
      </div>
    </div>
  </section>

  <div class="pt-20">
    <CTA
      title="Your brand could be on this page"
      text="Start with a single style or a sample run — that's how most of our longest client relationships began."
    />
  </div>
</Base>
