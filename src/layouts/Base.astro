---
import '../styles/global.css';
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import frauncesLatin from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import MobileActionBar from '../components/MobileActionBar.astro';
import { site, defaultTheme } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  dateModified?: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
  ogType?: 'website' | 'article';
  breadcrumbs?: Array<{ name: string; href: string }>;
  faqItems?: ReadonlyArray<{ q: string; a: string }>;
  structuredData?: Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  dateModified,
  image = '/og.png',
  imageAlt = 'YK Apparels — knitwear manufacturer in Lahore, Pakistan',
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  ogType = 'website',
  breadcrumbs: suppliedBreadcrumbs,
  faqItems,
  structuredData = [],
} = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL(image, Astro.site);
const logoImage = new URL('/apple-touch-icon.png', Astro.site);
const verifiedSocialProfiles = Object.values(site.socials).filter(Boolean);

const organization = {
  '@type': ['Organization', 'LocalBusiness'],
  '@id': `${site.url}/#organization`,
  name: site.name,
  description: site.description,
  slogan: 'Designs in. Garments out.',
  url: site.url,
  logo: String(logoImage),
  image: String(ogImage),
  email: site.email,
  telephone: site.phone,
  foundingDate: String(site.founded),
  priceRange: '$$',
  areaServed: [
    { '@type': 'Country', name: 'Pakistan' },
    { '@type': 'Country', name: 'United States' },
    { '@type': 'Country', name: 'United Kingdom' },
    { '@type': 'Place', name: 'Europe' },
  ],
  knowsAbout: [
    'Custom knitwear manufacturing',
    'Sweater and cardigan manufacturing',
    'Knitted polo manufacturing',
    'Knitwear sampling and product development',
    'Private-label garment production',
    'Knitwear quality control',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: site.email,
    telephone: site.phone,
    availableLanguage: ['en', 'ur'],
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressCountry: 'PK',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 31.4487359,
    longitude: 74.2556698,
  },
  hasMap: site.mapsHref,
  ...(verifiedSocialProfiles.length > 0 ? { sameAs: verifiedSocialProfiles } : {}),
};

const website = {
  '@type': 'WebSite',
  '@id': `${site.url}/#website`,
  url: `${site.url}/`,
  name: site.name,
  description: site.description,
  publisher: { '@id': `${site.url}/#organization` },
  inLanguage: 'en',
};

const webPage = {
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  url: String(canonical),
  name: title,
  description,
  isPartOf: { '@id': `${site.url}/#website` },
  about: { '@id': `${site.url}/#organization` },
  primaryImageOfPage: String(ogImage),
  inLanguage: 'en',
  ...(dateModified ? { dateModified } : {}),
};

// Breadcrumb trail for inner pages (Home → Page)
const pageLabels: Record<string, string> = {
  '/capabilities/': 'Capabilities',
  '/about/': 'About & Facility',
  '/clients/': 'Clients',
  '/contact/': 'Contact',
  '/privacy/': 'Privacy Policy',
};
const path = canonical.pathname;
const breadcrumbItems = suppliedBreadcrumbs ??
  (path !== '/' && pageLabels[path]
    ? [{ name: pageLabels[path], href: path }]
    : []);
const breadcrumbs =
  breadcrumbItems.length > 0
    ? {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { name: 'Home', href: '/' },
          ...breadcrumbItems,
        ].map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          item: String(new URL(item.href, Astro.site)),
        })),
      }
    : null;

// FAQ schema is emitted only when the same questions are visible on the page.
const faqSchema =
  faqItems && faqItems.length > 0
    ? {
        '@type': 'FAQPage',
        mainEntity: faqItems.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      }
    : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organization, website, webPage, breadcrumbs, faqSchema, ...structuredData].filter(Boolean),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#14563e" />

    <!-- Bing Webmaster Tools verification (also unlocks ChatGPT web search). Keep permanently. -->
    <meta name="msvalidate.01" content="71582AE692155680528DC1D843B18729" />

    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={frauncesLatin} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Theme init: runs before paint to avoid a flash of the wrong theme.
         Priority: visitor's stored choice > configured default > system preference. -->
    <script is:inline define:vars={{ defaultTheme }}>
      (() => {
        // Progressive enhancement flag: .reveal animations only activate with JS present
        document.documentElement.classList.add('js');
        const stored = localStorage.getItem('theme');
        let theme;
        if (stored === 'light' || stored === 'dark') {
          theme = stored;
        } else if (defaultTheme === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        } else {
          theme = defaultTheme;
        }
        document.documentElement.dataset.theme = theme;
        // keep mobile browser chrome in sync with the active theme
        const tc = document.querySelector('meta[name="theme-color"]');
        if (tc) tc.content = theme === 'dark' ? '#0a1512' : '#14563e';
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    {path !== '/contact/' && <MobileActionBar />}
    <ConsentBanner />
    <script>
      type ConversionDetail = { name: string; location?: string };
      const trackConversion = ({ name, location }: ConversionDetail) => {
        const gtag = (window as Window & { gtag?: (...args: unknown[]) => void }).gtag;
        gtag?.('event', name, location ? { link_location: location } : undefined);
      };

      document.addEventListener('click', (event) => {
        const target = (event.target as Element | null)?.closest<HTMLElement>('[data-track-event]');
        if (!target) return;
        trackConversion({
          name: target.dataset.trackEvent ?? 'interaction',
          location: target.dataset.trackLocation,
        });
      });
      window.addEventListener('yk:conversion', (event) => {
        trackConversion((event as CustomEvent<ConversionDetail>).detail);
      });

      // Scroll reveal for elements carrying .reveal
      const revealables = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            }
          },
          // rootMargin pre-triggers reveals just below the fold so fast mobile
          // scrolling never lands on still-hidden content
          { threshold: 0.05, rootMargin: '0px 0px 12% 0px' },
        );
        revealables.forEach((el) => observer.observe(el));
        // Watchdog: above-fold reveals fire within milliseconds normally. If
        // nothing has revealed after 2s the observer is stalled/broken — show
        // everything rather than leave content invisible.
        if (revealables.length > 0) {
          setTimeout(() => {
            if (!document.querySelector('.reveal.revealed')) {
              revealables.forEach((el) => el.classList.add('revealed'));
            }
          }, 2000);
        }
      } else {
        revealables.forEach((el) => el.classList.add('revealed'));
      }
    </script>
  </body>
</html>
